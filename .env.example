# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=charts

# Backend
DATABASE_URL=postgres://user:password@postgres:5432/charts
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
PORT=3000

# Notion OAuth (get these from https://www.notion.so/my-integrations)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/integrations/notion/callback
APP_BASE_URL=http://localhost:3000
